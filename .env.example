# ─── Database (Neon) ───────────────────────────────────────────────
# Get these from your Neon project dashboard
# DATABASE_URL is the pooled connection string (-pooler endpoint)
# DIRECT_URL is the non-pooled direct connection string (migrations only)
DATABASE_URL="postgres://user:password@ep-xxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgres://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ─── Auth ─────────────────────────────────────────────────────────
# Generate AUTH_SECRET with: openssl rand -base64 32
AUTH_SECRET="your-32-byte-secret-here"

# Owner credentials (single admin user — no DB User table in Phase 1)
OWNER_EMAIL="owner@yourfarm.co.ke"
# Generate with: node -e "const b=require('bcryptjs');b.hash('your-password',12).then(console.log)"
# IMPORTANT: escape every "$" as "\$" — Next.js's env loader expands unescaped
# $VAR-looking sequences, which silently corrupts bcrypt hashes (they start with $2b$).
OWNER_PASSWORD_HASH="\$2b\$12\$..."

# ─── Cron ─────────────────────────────────────────────────────────
# Used to authenticate Vercel Cron calls to /api/cron/backup
# Generate with: openssl rand -base64 32
CRON_SECRET="your-cron-secret-here"
