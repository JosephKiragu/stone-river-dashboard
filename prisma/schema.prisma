generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── APP SETTINGS (singleton row, id = "global") ────────────────
model AppSettings {
  id               String   @id @default("global")
  marketPricePerKg Float?
  updatedAt        DateTime @updatedAt
}

// ─── PENS ─────────────────────────────────────────────────────────
model Pen {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  name        String
  capacity    Int?
  isActive    Boolean  @default(true)

  assignments PenAssignment[]
}

// ─── ANIMALS ──────────────────────────────────────────────────────
model Animal {
  id               String       @id @default(cuid())
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  tagId            String       @unique
  breed            String
  ageAtPurchaseMonths Int?
  purchaseDate     DateTime
  purchaseWeightKg Float
  purchasePriceKes Float
  purchaseMarket   String?
  status           AnimalStatus @default(ACTIVE)
  exitDate         DateTime?
  exitWeightKg     Float?
  exitPriceKes     Float?
  exitReason       String?

  assignments PenAssignment[]
  weightLogs  WeightLog[]
}

enum AnimalStatus {
  ACTIVE
  SOLD
  DEAD
  LOSS
}

// ─── PEN ASSIGNMENTS (history, not overwrite) ─────────────────────
model PenAssignment {
  id        String    @id @default(cuid())
  animalId  String
  animal    Animal    @relation(fields: [animalId], references: [id])
  penId     String
  pen       Pen       @relation(fields: [penId], references: [id])
  from      DateTime
  to        DateTime? // NULL = currently in this pen

  @@index([penId, from, to])
  @@index([animalId, to])
}

// ─── WEIGHTS ──────────────────────────────────────────────────────
model WeighSession {
  id         String      @id @default(cuid())
  createdAt  DateTime    @default(now())
  date       DateTime    @unique // one session per weigh day; UTC midnight
  notes      String?
  weightLogs WeightLog[]
}

model WeightLog {
  id        String        @id @default(cuid())
  createdAt DateTime      @default(now())
  animalId  String
  animal    Animal        @relation(fields: [animalId], references: [id])
  sessionId String?
  session   WeighSession? @relation(fields: [sessionId], references: [id])
  weightKg  Float
  loggedAt  DateTime      // weigh day — UTC midnight; matches WeighSession.date
  notes     String?

  @@unique([animalId, loggedAt])
  @@index([animalId, loggedAt])
}
